    />
    <ContactSection title="Sales & Partnerships." people="sales" />
    <br />
    <br />
    <ContactSection title="Marketing." people="marketing" />
    <br />
    <br />
    <ContactSection title="Devs." people="tech" />
    <br />
    <br />
    <ContactSection title="Operations." people="projectLead" />
    <br />
    <br />
