---
import Body from "../components/Body.astro";
import Content from "../components/Content.astro";
import Hero from "../components/Hero.astro";
import SubTitle from "../components/SubTitle.astro";
import Title from "../components/Title.astro";
import Layout from "../layouts/BaseLayout.astro";
import Partners from "../components/Partners.tsx";
---

<Layout
  title="For Talents"
  description="What value do we bring for the IT talent?"
>
  <Hero
    title="Infinite Career Paths - One Root."
    subtitle="Fueling the Next Generation of IT Talents"
    date="NOV 20, 2025 IN TURKU"
  />
  <Content>
    <Title text="MISSION" />
    <SubTitle text="You don’t need to be perfect — just curious." />
    <Body
      text=`Our event brings together the most exciting IT companies and talented people in the Turku region. The goal is simple: easy, approachable networking, giving students and recent graduates a real-life taste of working culture and helping companies learn about future professionals. Everyone’s welcome—no sign-up needed!`
    />
    <Title text="NUMBERS" />
    <Body
      text=`How many students among 7+ IT student societies: 4000+
How many side events: 5+ side events by companies (pääpuhe, main partner keynote, job dating, muu lavaohjelma, workshop ja afterwork)
Companies: 1# most valuable IT Job Fair in Turku region
`
    />
    <Body text=`4,000+ Reach through 7+ student societies` />
    <Body text=`#1 IT Job Fair in Turku` />
    <Body text=`5+ side events` />
    <Body text=`50+ speed interviews` />
    <Body text=`3 universities, 1 event` />
    <Title text="FIRST JOB WORKSHOP" />
    <Body
      text=`Join our practical workshop designed for especially students applying for their first IT job. Learn exactly what employers are looking for, how to showcase your skills effectively, and get useful, hands-on tips to confidently approach your first job applications.`
    />
  </Content>
  <Title text="PARTNERS" />
  <Partners client:load />
  <Partners client:load scrollDirection="reverse" partnersGroup="1" />
</Layout>
