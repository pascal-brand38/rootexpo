---
import Title from "../components/Title.astro";
import Layout from "../layouts/BaseLayout.astro";
import PartnersStatic from "../components/PartnersStatic.tsx";
import PartnersScroller from "../components/PartnersScroller.tsx";
import PartnersLogoScroller from "../components/PartnersLogoScroller.tsx";
import MatterportEmbed from "../components/MatterportEmbed.astro";
import ScrollProgressBar from '../components/ScrollProgressBar';
import ScrollToTopButton from '../components/ScrollToTopButton';
import FaqSection from "../components/FaqSection.astro";
import SpeakerSection from "../components/SpeakerSection.astro";
---

<Layout title="Dev Page" tags={[]}>
  <ScrollProgressBar client:load />
  <MatterportEmbed url="https://my.matterport.com/show/?m=13UZgtiVvEr" />
  <PartnersStatic />
  <Title text="No BG Scroller" />
  <PartnersLogoScroller client:load />
  <PartnersLogoScroller
    client:load
    scrollDirection="reverse"
    partnersGroup="1"
  />
  <Title text="Old scroller" />
  <PartnersScroller client:load />
  <PartnersScroller client:load scrollDirection="reverse" partnersGroup="1" />
  <ScrollToTopButton client:load />
  <FaqSection />
  <SpeakerSection />
</Layout>
