---
import Body from "../components/Body.astro";
import Content from "../components/Content.astro";
import Hero from "../components/Hero.astro";
import Title from "../components/Title.astro";
import Layout from "../layouts/BaseLayout.astro";
import NumberCards from "../components/NumberCards.astro";
---

<Layout
  title="Root IT Career Fair"
  description="Root brings together the most exciting companies and talented IT people in the Turku region. 20 November 2025 at the Visitor Centre Joki in Turku, Finland."
  tags={[
    "Root Turku",
    "Root Expo",
    "Career Fair",
    "Junior IT jobs",
    "Professional Growth",
    "Networking",
    "Job Dating",
    "CV Workshop",
  ]}
>
  <Hero
    title="INFINITE PATHS. ONE ROOT."
    subtitle="FUELING THE NEXT GENERATION OF IT TALENT."
    date="COMING 20.11.2025"
  />
  <Content>
    <Title text="YOU DON'T NEED TO BE PERFECT — JUST CURIOUS." />
    <Body
      text=`Root brings together the most exciting companies and talented IT people in the Turku region. The event will be held on 20 November 2025 at the Visitor & Innovation Centre Joki in Turku, Finland. Join us for inspiring speakers, interactive workshops, and engaging networking. This is an adventure where everyone's welcome—no sign-up needed!`
    />
    <Body text=`` />
    <Title text="WHAT MAKES US DIFFERENT" />
    <NumberCards
      cards={[
        {
          number: "4000+",
          description: "TALENT REACH IN OUR NETWORK",
        },
        {
          number: "5+",
          description: "SIDE EVENTS",
        },
        {
          number: "#1",
          description: "IT CAREER FAIR IN TURKU",
        },
        {
          number: "100 %",
          description: "FOCUS ON IT",
        },
      ]}
    />
    <!-- <Title text="SIDE EVENTS" /> 
    <Body text=`Keynotes. Workshops. Afterwork.` /> -->
  </Content>
</Layout>
