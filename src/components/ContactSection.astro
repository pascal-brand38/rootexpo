---
import ContactCard from "./ContactCard.astro";
import Title from "./Title.astro";
import contacts from "../data/contacts.json";

interface Props {
  title?: string;
  people: "projectLead" | "sales" | "tech" | "marketing" | "production" | "movie";
}

const { title, people } = Astro.props;
const contactList = contacts[people] ?? [];
---

<Title text={title || ""} />
<br />
<div
  class="grid grid-cols-1 lg:grid-cols-2 xl:grid-cols-3 gap-8 max-w-[820px] xl:max-w-[1280px] mx-auto px-6 mb-8"
>
  {
    contactList.map((contact) => (
      <ContactCard
        name={contact.name}
        title={contact.title}
        email={contact.email}
        phone={contact.phone}
        image={contact.image}
        linkedin={contact.linkedin}
        text={contact.text}
      />
    ))
  }
</div>
