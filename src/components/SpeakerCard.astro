---
interface Props {
  image: string;
  name: string;
  title: string;
  text: string;
}
const { image, name, title, text } = Astro.props;
---

<div class="speaker-card relative bg-container rounded-lg overflow-hidden w-[300px] md:w-auto lg:w-auto flex-shrink-0">
  <div class="relative w-full">
    <img 
      src={image} 
      alt={name} 
      class="w-[300px] h-[300px] md:w-[390px] md:h-[390px] lg:w-[390px] lg:h-[390px] display object-cover rounded-lg mx-auto mb-4 shadow-md scale-100"
    />

    <div class="absolute bottom-0 inset-x-0 w-full h-[5px] bg-accent z-20 my-50"></div>
  </div>
  <div class="p-6 -mt-3">
    <h2>
      {name}
    </h2>
    <h5 class="text-accent">
      {title}
    </h5>
  </div>
</div>

<style>
  .speaker-card img {
    filter: grayscale(100%);
    transition: filter 0.3s ease, transform 0.3s ease;
  }
</style>

  <!.speaker-card:hover img {filter: grayscale(0%);}>