---
interface Props {
    number: string;
    description: string;
}

const { number, description } = Astro.props;
---

<div class="hover-card bg-container flex flex-col items-center justify-center px-4 py-6 md:px-12 lg:px-6 rounded-lg md:rounded-2xl lg:rounded-4xl max-w-[250px] md:max-w-[300px] lg:max-w-[450px] transition-all duration-300 ease-in-out">
    <h1 class="text-center text-2xl md:text-4xl lg:text-5xl font-bold transition-colors duration-300">
        {number}
    </h1>
    <p class="text-base text-center md:text-lg lg:text-xl mt-2 transition-colors duration-300">
        {description}
    </p>
</div>

<style>
    .hover-card {
        position: relative;
        overflow: hidden;
        box-shadow: 0 0 0 0 rgba(255, 255, 255, 0);
        transform: translateY(0);
    }
    
    .hover-card::before {
        content: "";
        position: absolute;
        inset: 0;
        border-radius: inherit;
        padding: 2px;
        background: linear-gradient(
            135deg, 
            rgba(255, 255, 255, 0) 0%, 
            rgba(200, 150, 255, 0.15) 50%, 
            rgba(255, 255, 255, 0) 100%
        );
        -webkit-mask: 
            linear-gradient(#fff 0 0) content-box, 
            linear-gradient(#fff 0 0);
        -webkit-mask-composite: xor;
        mask-composite: exclude;
        opacity: 0;
        transition: opacity 0.3s ease;
    }
    
    .hover-card:hover {
        transform: translateY(-5px) scale(1.02);
        box-shadow: 0 10px 20px -5px rgba(128, 0, 255, 0.15), 
                    0 0 15px rgba(200, 0, 255, 0.1);
    }
    
    .hover-card:hover::before {
        opacity: 1;
    }
    
    .hover-card:hover h1,
    .hover-card:hover p {
        color: rgba(255, 255, 255, 0.95);
        text-shadow: 0 0 8px rgba(200, 150, 255, 0.3);
    }
</style>
