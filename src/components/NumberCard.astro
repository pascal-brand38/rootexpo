---
interface Props {
    number: string;
    description: string;
}

const { number, description } = Astro.props;
---

<div class="bg-container w-full h-full p-4 rounded-lg">
    <h4 class="text-center break-words transition-colors duration-300">
        {number}
    </h4>
    <p class="text-center mt-2 break-normal transition-colors duration-300">
        {description}
    </p>
</div>