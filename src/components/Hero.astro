---
interface Props {
  title: string;
  subtitle: string;
  date: string;
}

const { title, subtitle, date } = Astro.props;
---

<div class="w-screen h-screen flex flex-col justify-end gap-4">
  <video
    autoplay
    loop
    muted
    playsinline
    class="absolute inset-0 w-full h-full object-cover -z-30"
  >
    <source src="/hero.webm" type="video/webm" />
    Your browser does not support the video tag :(
  </video>

  <!-- Radial overlay go brrrr -->
  <div
    class="absolute top-0 left-0 w-full h-full bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-transparent to-background -z-20"
  >
  </div>

  <div
    class="mb-[25vh] px-4 w-full max-w-full md:max-w-[75vw] md:px-8 lg:px-14 xl:px-20"
  >
    <h3 class="text-accent font-bold text-base md:text-lg lg:text-xl">
      {date}
    </h3>
    <h1
      class="font-bold text-2xl sm:text-3xl md:text-4xl lg:text-5xl xl:text-6xl"
    >
      {title}
    </h1>
    <h5 class="text-sm sm:text-base md:text-lg lg:text-xl xl:text-2xl">
      {subtitle}
    </h5>
  </div>
</div>
