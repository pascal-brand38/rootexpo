---
interface Props {
  title: string;
  subtitle: string;
}

const { title, subtitle } = Astro.props;
---

<div class="">
  <div class="absolute top-0 left-0 h-screen w-screen overflow-hidden -z-10">
    <video
      autoplay
      loop
      muted
      playsinline
      class="h-screen w-screen bg-background object-cover object-left -z-20"
    >
      <source src="/hero.webm" type="video/webm" />
      Your browser does not support the video tag. :(
    </video>
  </div>

  <!-- Radial overlay go brrrr -->
  <div
    class="absolute top-0 left-0 w-screen h-screen bg-[radial-gradient(ellipse_100%_50%_at_center,_var(--tw-gradient-stops))] from-transparent to-background -z-10"
  >
  </div>

  <div class="max-w-[1280px] mx-auto mt-[50vh]">
    <h1 class="">
      {title}
    </h1>

    <p class="">
      {subtitle}
    </p>
  </div>
</div>
