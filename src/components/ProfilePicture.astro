---
interface Props {
  image?: string;
  alt?: string;
}

const {
  image = "/logos/rooticon_white.svg",
  alt = "Contact Icon",
} = Astro.props;

const finalImage = image?.trim() ? image : "/logos/rooticon_white.svg";
---

<img
  src={finalImage}
  alt={alt}
  class="w-full h-full object-cover"
/>
