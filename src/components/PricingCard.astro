---
interface Props {
  name: string;
  price: string;
  points: string[];
  text: string;
}
const { name, price, points, text } = Astro.props;
---

<div
  class="bg-container flex flex-col self-stretch place-self-center align-start justify-start px-10 py-10 md:px-12 md:py-15 lg:px-14 lg:py-20 rounded-lg md:rounded-2xl lg:rounded-4xl max-w-[500px]"
>
  <h5 class="">{name}</h5>
  <h2 class="">
    Starting from <p class="text-accent">{price}</p>
  </h2>
  <p class="">What's included?</p>
  <ul>
    {
      points.flatMap((point) => {
        return (
          <li class="flex items-center my-2 md:my-3 lg:my-4">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="text-accent mr-2 mt-1 h-5 w-5 min-w-5 min-h-5 self-start"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M5 13l4 4L19 7"
              />
            </svg>
            {point}
          </li>
        );
      })
    }
  <p class="">{text}</p>
  </ul>
</div>


