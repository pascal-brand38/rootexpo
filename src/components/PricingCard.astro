---
interface Props {
  name: string;
  price: string;
  points: string[];
  text: string;
}
const { name, price, points, text } = Astro.props;
---

<div
  class="bg-container flex flex-col align-start self-stretch place-self-center justify-start rounded-lg max-w-[500px] py-8 p-6"
>
  <h5 class="">
    {name}
  </h5>
  <h3 class="">
    STARTING FROM <span class="text-accent">{price}</span>
  </h3>
  <p class="">What's included?</p>
  <ul>
    {
      points.flatMap((point) => {
        return (
          <li class="flex items-center ml-6 my-2 md:my-3 lg:my-4">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="text-accent mr-2 mt-1 h-5 w-5 min-w-5 min-h-5 self-start"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M5 13l4 4L19 7"
              />
            </svg>
            {point}
          </li>
        );
      })
    }
  <p class="">{text}</p>
  </ul>
</div>


