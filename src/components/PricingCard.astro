---
interface Props {
  name: string;
  price: string;
  points: string[];
  text: string;
}
const { name, price, points, text } = Astro.props;
---

<div
  class="bg-container flex flex-col self-stretch place-self-center align-start justify-start px-10 py-10 md:px-12 md:py-15 lg:px-14 lg:py-20 rounded-lg md:rounded-2xl lg:rounded-4xl max-w-[500px]"
>
  <h2 class="text-lg md:text-xl lg:text-2xl">{name}</h2>
  <h1 class="text-xl md:text-3xl lg:text-4xl">
    Starting from <p class="text-accent">{price}</p>
  </h1>
  <p class="text-base md:text-lg lg:text-xl">What's included?</p>
  <ul>
    {
      points.flatMap((point) => {
        return (
          <li class="flex items-center leading-tight text-base md:text-md lg:text-lg my-2 md:my-3 lg:my-4">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="text-accent mr-2 h-5 w-5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M5 13l4 4L19 7"
              />
            </svg>
            {point}
          </li>
        );
      })
    }
  <p class="text-base md:text-lg lg:text-xl">{text}</p>
  </ul>
</div>
